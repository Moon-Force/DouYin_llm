# Live room
ROOM_ID=
COLLECTOR_ENABLED=true
COLLECTOR_HOST=127.0.0.1
COLLECTOR_PORT=1088
COLLECTOR_PING_INTERVAL_SECONDS=30
COLLECTOR_RECONNECT_DELAY_SECONDS=3

# Backend
APP_HOST=127.0.0.1
APP_PORT=8010

# Suggestion LLM
# Used for reply/suggestion generation only.
# This is separate from the local memory extractor below.
LLM_MODE=qwen
DASHSCOPE_API_KEY=your_dashscope_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus-latest
LLM_TIMEOUT_SECONDS=6
LLM_TEMPERATURE=0.4

# Embedding
EMBEDDING_MODE=cloud
EMBEDDING_STRICT=false
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=10
LOCAL_EMBEDDING_DEVICE=cpu
LOCAL_EMBEDDING_BATCH_SIZE=32

# Semantic Retrieval
SEMANTIC_MEMORY_MIN_SCORE=0.35
SEMANTIC_MEMORY_QUERY_LIMIT=6
SEMANTIC_FINAL_K=3

# Local Memory Extractor
# Used only for viewer memory extraction.
# Set MEMORY_EXTRACTOR_ENABLED=true to let memory extraction use a local GGUF model.
# MEMORY_EXTRACTOR_MODE defaults to local for the built-in on-device extractor runtime.
# Leave MEMORY_EXTRACTOR_MODEL_PATH blank to use the app default global model directory.
# Default global directory:
# - Windows: %LOCALAPPDATA%\DouYinLLM\models\memory_extractor
# - Other OS: ~/.douyin_llm/models/memory_extractor
# If MEMORY_EXTRACTOR_MODEL_URL is set and the model file is missing, the app will download it automatically.
# If MEMORY_EXTRACTOR_MODEL_URL is blank, place the GGUF file manually in the model directory above.
# MEMORY_EXTRACTOR_MODEL_PATH can also point to a custom model directory or a specific GGUF file.
# Leave MEMORY_EXTRACTOR_THREADS blank to use the runtime default thread count.
MEMORY_EXTRACTOR_ENABLED=false
MEMORY_EXTRACTOR_MODE=local
MEMORY_EXTRACTOR_MODEL_PATH=
MEMORY_EXTRACTOR_MODEL_URL=
MEMORY_EXTRACTOR_MODEL_FILENAME=memory-extractor.gguf
MEMORY_EXTRACTOR_CONTEXT_SIZE=4096
MEMORY_EXTRACTOR_MAX_TOKENS=512
MEMORY_EXTRACTOR_TIMEOUT_SECONDS=30
MEMORY_EXTRACTOR_THREADS=

# Memory
REDIS_URL=
DATA_DIR=data
DATABASE_PATH=data/live_prompter.db
CHROMA_DIR=data/chroma
SESSION_TTL_SECONDS=14400
